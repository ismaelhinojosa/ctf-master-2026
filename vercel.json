{
  "cleanUrls": true,
  "redirects": [
    { "source": "/.env", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/config", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/config/(.*)", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/api/credentials", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/api/credentials/(.*)", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/backup", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/backup/(.*)", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/admin", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/admin/(.*)", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/database", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/database/(.*)", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/private", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/private/(.*)", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/secrets", "destination": "/admin_backdoor_secret.html", "permanent": false },
    { "source": "/secrets/(.*)", "destination": "/admin_backdoor_secret.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
